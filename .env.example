# Puerto del market-api (cambiar si 8080 está ocupado en tu servidor)
API_PORT=8080

# OKX API credentials
# Get these from: OKX > Account > API Management
OKX_API_KEY=your_api_key_here
OKX_SECRET_KEY=your_secret_key_here
OKX_PASSPHRASE=your_passphrase_here

# Set to true to use OKX demo/paper trading account
OKX_DEMO=true

# Trading parameters
LEVERAGE=3

# Pairs to analyze (comma-separated, no spaces)
SYMBOLS=BTC-USDT-SWAP,ETH-USDT-SWAP,SOL-USDT-SWAP,BNB-USDT-SWAP

# LLM model to use via Ollama
# Options: qwen2.5:7b, qwen2.5:14b, qwen2.5:32b, llama3.3:70b
LLM_MODEL=qwen2.5:14b

# How often the agent runs (in minutes)
# 4H strategy: 30 minutes is sufficient
CYCLE_INTERVAL_MINUTES=30

# DRY_RUN=true  → agent logs decisions but does NOT execute real orders
# DRY_RUN=false → agent executes real orders on OKX
DRY_RUN=true
